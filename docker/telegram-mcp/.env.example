# Get credentials at https://my.telegram.org/apps
TG_APP_ID=12345678
TG_API_HASH=abcdef1234567890abcdef1234567890

# Only needed for the first run (init)
TG_PHONE=+79001234567

# Uncomment if two-factor authentication is enabled
# TG_2FA_PASSWORD=your_2fa_password

# Proxy — required
PROXY_HOST=your.proxy.host
PROXY_PORT=1080

# Proxy authentication — leave empty if not needed
PROXY_USER=
PROXY_PASS=

# MCP server port
MCP_PORT=8080
